APP_NAME=IPB Open Source Backend
DEFAULT_AREA=North Karelia
DEFAULT_TIMEFRAME=72h
AUTO_REFRESH=false
REFRESH_INTERVAL_SECONDS=1800

# Analysis provider: "claude" (recommended), "ollama", "rules" (fallback)
ANALYSIS_PROVIDER=claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b

NLS_API_KEY=
DIGIROAD_API_KEY=
STATISTICS_FINLAND_API_KEY=
OPENCELLID_API_KEY=
